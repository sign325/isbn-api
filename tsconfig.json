{
	"compilerOptions": {
		"target": "es2024",
		"lib": ["es2024"],
		"jsx": "react-jsx",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"resolveJsonModule": true,
		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"exclude": ["test"],
	"include": ["src/**/*.ts"]
}
